# Default to SQLite for a friction-free scaffold. Use Postgres for real dev.
# DATABASE_URL=postgresql+psycopg://ticketportal:ticketportal@localhost:5432/ticketportal
DATABASE_URL=sqlite:///./instance/ticketportal.db

# Optional read replica (kept unset to default reader = writer).
# DATABASE_URL_REPLICA=postgresql+psycopg://reader:reader@replica.local:5432/ticketportal

# Redis is optional; when reachable enables permission cache, rate
# limiting and Idempotency-Key replay.
REDIS_URL=redis://localhost:6379/0

FLASK_ENV=development
SECRET_KEY=change-me-in-prod
JWT_SECRET_KEY=change-me-too-in-prod
JWT_ACCESS_MIN=15
JWT_REFRESH_DAYS=7

# Object storage. In dev we use the local filesystem via the AttachmentStorage adapter.
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage

# CORS (Vite dev frontend)
CORS_ORIGINS=http://localhost:5173

# Rate limit defaults (per scope, applied with @rate_limit decorator).
RATELIMIT_LOGIN_PER_MIN=10
RATELIMIT_TICKET_CREATE_PER_MIN=60
